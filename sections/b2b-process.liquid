{% render 'b2b-styles' %}
<style>
.b2b-page .process-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .process-timeline {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.b2b-page .process-item {
  display: flex;
  gap: 32px;
  padding: 40px 48px;
  border-bottom: 1px solid var(--border);
  border-right: 1px solid var(--border);
  align-items: flex-start;
}
.b2b-page .process-item:nth-child(even) { border-right: none; }
.b2b-page .process-item:nth-child(3),
.b2b-page .process-item:nth-child(4) { border-bottom: none; }
.b2b-page .process-num-big {
  font-size: 56px;
  font-weight: 300;
  line-height: 1;
  opacity: 0.1;
  flex-shrink: 0;
  width: 60px;
}
.b2b-page .process-step-title {
  font-size: 13px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 12px;
  font-weight: 500;
}
.b2b-page .process-step-text {
  font-size: 15px;
  line-height: 1.7;
  opacity: 0.6;
  font-weight: 300;
}
@media (max-width: 768px) {
  .b2b-page .process-section { padding: 48px 24px; }
  .b2b-page .process-timeline { grid-template-columns: 1fr; }
  .b2b-page .process-item { border-right: none !important; border-bottom: 1px solid var(--border) !important; padding: 32px 0; }
  .b2b-page .process-item:last-child { border-bottom: none !important; }
}
</style>

<div class="process-section">
  <p class="section-label">{{ section.settings.process_label }}</p>
  <p class="section-title">{{ section.settings.process_title }}</p>
  <div class="process-timeline">
    <div class="process-item">
      <div class="process-num-big">01</div>
      <div>
        <p class="process-step-title">{{ section.settings.process_1_title }}</p>
        <p class="process-step-text">{{ section.settings.process_1_text }}</p>
      </div>
    </div>
    <div class="process-item">
      <div class="process-num-big">02</div>
      <div>
        <p class="process-step-title">{{ section.settings.process_2_title }}</p>
        <p class="process-step-text">{{ section.settings.process_2_text }}</p>
      </div>
    </div>
    <div class="process-item">
      <div class="process-num-big">03</div>
      <div>
        <p class="process-step-title">{{ section.settings.process_3_title }}</p>
        <p class="process-step-text">{{ section.settings.process_3_text }}</p>
      </div>
    </div>
    <div class="process-item">
      <div class="process-num-big">04</div>
      <div>
        <p class="process-step-title">{{ section.settings.process_4_title }}</p>
        <p class="process-step-text">{{ section.settings.process_4_text }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "B2B — The Process",
  "tag": "div",
  "class": "b2b-page",
  "settings": [
    { "type": "text", "id": "process_label", "label": "Section Label", "default": "How It Works" },
    { "type": "text", "id": "process_title", "label": "Section Title", "default": "The Process" },
    { "type": "header", "content": "Step 1" },
    { "type": "text", "id": "process_1_title", "label": "Title", "default": "Consultation" },
    { "type": "textarea", "id": "process_1_text", "label": "Text", "default": "We meet to understand your project brief, timeline and requirements — in person at our Dubai Hills showroom or virtually." },
    { "type": "header", "content": "Step 2" },
    { "type": "text", "id": "process_2_title", "label": "Title", "default": "Design & Specification" },
    { "type": "textarea", "id": "process_2_text", "label": "Text", "default": "Our team prepares detailed specifications, material samples and renders tailored to your project and client's vision." },
    { "type": "header", "content": "Step 3" },
    { "type": "text", "id": "process_3_title", "label": "Title", "default": "Production" },
    { "type": "textarea", "id": "process_3_text", "label": "Text", "default": "All bespoke pieces are handcrafted in our Dubai facility with full quality oversight and regular progress updates." },
    { "type": "header", "content": "Step 4" },
    { "type": "text", "id": "process_4_title", "label": "Title", "default": "Delivery & Installation" },
    { "type": "textarea", "id": "process_4_text", "label": "Text", "default": "White glove delivery and professional installation, coordinated around your project schedule across the UAE and GCC." }
  ],
  "presets": [{ "name": "B2B — The Process" }]
}
{% endschema %}
