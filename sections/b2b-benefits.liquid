{% render 'b2b-styles' %}
<style>
.b2b-page .benefits-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .benefits-v2 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid var(--border);
  border-left: 1px solid var(--border);
}
.b2b-page .benefit-v2 {
  padding: 40px 32px;
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.b2b-page svg.benefit-v2-icon {
  width: 44px;
  height: 44px;
  margin-bottom: 20px;
  stroke: #8b7355;
}
.b2b-page .benefit-v2-title {
  font-size: 13px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 10px;
  font-weight: 500;
}
.b2b-page .benefit-v2-text {
  font-size: 14px;
  line-height: 1.6;
  opacity: 0.55;
  font-weight: 300;
}
@media (max-width: 768px) {
  .b2b-page .benefits-section { padding: 48px 24px; }
  .b2b-page .benefits-v2 { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 425px) {
  .b2b-page .benefits-section { padding: 20px; }
  .b2b-page .benefit-v2 { padding: 20px; }
  .b2b-page .benefit-v2-title { font-size: 11px; }
  .b2b-page .benefit-v2-text { font-size: 12px; }
}
@media (max-width: 375px) {
  .b2b-page .benefits-v2 { grid-template-columns: 1fr; }
}
</style>

<div class="benefits-section">
  <p class="section-label">{{ section.settings.benefits_label }}</p>
  <p class="section-title">{{ section.settings.benefits_title }}</p>
  <div class="benefits-v2">
    <div class="benefit-v2">
      <svg class="benefit-v2-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
        <path d="M8 20h24M20 8v24"/><circle cx="20" cy="20" r="14"/>
      </svg>
      <p class="benefit-v2-title">{{ section.settings.benefit_1_title }}</p>
      <p class="benefit-v2-text">{{ section.settings.benefit_1_text }}</p>
    </div>
    <div class="benefit-v2">
      <svg class="benefit-v2-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
        <rect x="8" y="12" width="24" height="18" rx="1"/><path d="M14 12V9a6 6 0 0112 0v3"/>
      </svg>
      <p class="benefit-v2-title">{{ section.settings.benefit_2_title }}</p>
      <p class="benefit-v2-text">{{ section.settings.benefit_2_text }}</p>
    </div>
    <div class="benefit-v2">
      <svg class="benefit-v2-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
        <circle cx="20" cy="14" r="6"/><path d="M8 32c0-6.627 5.373-12 12-12s12 5.373 12 12"/>
      </svg>
      <p class="benefit-v2-title">{{ section.settings.benefit_3_title }}</p>
      <p class="benefit-v2-text">{{ section.settings.benefit_3_text }}</p>
    </div>
    <div class="benefit-v2">
      <svg class="benefit-v2-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
        <path d="M10 30V16l10-8 10 8v14"/><rect x="16" y="22" width="8" height="8"/>
      </svg>
      <p class="benefit-v2-title">{{ section.settings.benefit_4_title }}</p>
      <p class="benefit-v2-text">{{ section.settings.benefit_4_text }}</p>
    </div>
    <div class="benefit-v2">
      <svg class="benefit-v2-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
        <rect x="8" y="8" width="10" height="10"/><rect x="22" y="8" width="10" height="10"/>
        <rect x="8" y="22" width="10" height="10"/><rect x="22" y="22" width="10" height="10"/>
      </svg>
      <p class="benefit-v2-title">{{ section.settings.benefit_5_title }}</p>
      <p class="benefit-v2-text">{{ section.settings.benefit_5_text }}</p>
    </div>
    <div class="benefit-v2">
      <svg class="benefit-v2-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
        <path d="M10 20h20M20 10v20"/><path d="M10 10l20 20M30 10L10 30"/>
      </svg>
      <p class="benefit-v2-title">{{ section.settings.benefit_6_title }}</p>
      <p class="benefit-v2-text">{{ section.settings.benefit_6_text }}</p>
    </div>
    <div class="benefit-v2">
      <svg class="benefit-v2-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
        <circle cx="20" cy="20" r="12"/><path d="M20 8v4M20 28v4M8 20h4M28 20h4"/>
      </svg>
      <p class="benefit-v2-title">{{ section.settings.benefit_7_title }}</p>
      <p class="benefit-v2-text">{{ section.settings.benefit_7_text }}</p>
    </div>
    <div class="benefit-v2">
      <svg class="benefit-v2-icon" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.2">
        <rect x="10" y="10" width="20" height="26" rx="1"/><path d="M15 18h10M15 23h10M15 28h6"/>
      </svg>
      <p class="benefit-v2-title">{{ section.settings.benefit_8_title }}</p>
      <p class="benefit-v2-text">{{ section.settings.benefit_8_text }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "B2B — Partner Benefits",
  "tag": "div",
  "class": "b2b-page",
  "settings": [
    { "type": "text", "id": "benefits_label", "label": "Section Label", "default": "Trade Programme" },
    { "type": "text", "id": "benefits_title", "label": "Section Title", "default": "Partner Benefits" },
    { "type": "header", "content": "Benefit 1" },
    { "type": "text", "id": "benefit_1_title", "label": "Title", "default": "Trade Pricing" },
    { "type": "textarea", "id": "benefit_1_text", "label": "Text", "default": "Exclusive rates for registered trade partners on all products and services." },
    { "type": "header", "content": "Benefit 2" },
    { "type": "text", "id": "benefit_2_title", "label": "Title", "default": "Referral Commission" },
    { "type": "textarea", "id": "benefit_2_text", "label": "Text", "default": "Earn commission on every referral through our structured partnership programme." },
    { "type": "header", "content": "Benefit 3" },
    { "type": "text", "id": "benefit_3_title", "label": "Title", "default": "Account Manager" },
    { "type": "textarea", "id": "benefit_3_text", "label": "Text", "default": "A dedicated account manager for every trade partner from day one." },
    { "type": "header", "content": "Benefit 4" },
    { "type": "text", "id": "benefit_4_title", "label": "Title", "default": "Priority Production" },
    { "type": "textarea", "id": "benefit_4_text", "label": "Text", "default": "Trade partners receive priority scheduling across all production lines." },
    { "type": "header", "content": "Benefit 5" },
    { "type": "text", "id": "benefit_5_title", "label": "Title", "default": "Custom Sizing" },
    { "type": "textarea", "id": "benefit_5_text", "label": "Text", "default": "Every piece made to your exact project dimensions — no standard sizes." },
    { "type": "header", "content": "Benefit 6" },
    { "type": "text", "id": "benefit_6_title", "label": "Title", "default": "Site Measurements" },
    { "type": "textarea", "id": "benefit_6_text", "label": "Text", "default": "Our team visits your project site to take precise measurements before production." },
    { "type": "header", "content": "Benefit 7" },
    { "type": "text", "id": "benefit_7_title", "label": "Title", "default": "GCC Project Support" },
    { "type": "textarea", "id": "benefit_7_text", "label": "Text", "default": "Full delivery and installation support across UAE, Saudi Arabia and GCC." },
    { "type": "header", "content": "Benefit 8" },
    { "type": "text", "id": "benefit_8_title", "label": "Title", "default": "Material Samples" },
    { "type": "textarea", "id": "benefit_8_text", "label": "Text", "default": "Access to our full library of material and fabric samples for client presentations." }
  ],
  "presets": [{ "name": "B2B — Partner Benefits" }]
}
{% endschema %}
