<link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
.b2b-page {
  --bg: #f0eeea;
  --dark: #1c1c1c;
  --white: #ffffff;
  --border: #d8d5d0;
  font-family: 'Instrument Sans', sans-serif;
  background: var(--bg);
  color: var(--dark);
  font-weight: 400;
  width: 100%;
}
.b2b-page .section-label {
  font-size: 12px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  opacity: 0.5;
  margin-bottom: 12px;
  text-align: center;
}
.b2b-page .section-title {
  font-size: 15px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-align: center;
  margin-bottom: 50px;
  font-weight: 500;
}

/* HERO */
.b2b-page .hero {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.b2b-page .hero-img {
  position: absolute;
  inset: 0;
  background-image: url('https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=1600&q=80');
  background-size: cover;
  background-position: center;
}
.b2b-page .hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45);
}
.b2b-page .hero-content {
  position: relative;
  text-align: center;
  color: #fff;
  max-width: 800px;
  padding: 0 40px;
}
.b2b-page .hero-label {
  font-size: 13px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 28px;
  opacity: 0.8;
}
.b2b-page .hero-title {
  font-size: 42px;
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  line-height: 1.3;
  margin-bottom: 28px;
}
.b2b-page .hero-sub {
  font-size: 17px;
  font-weight: 300;
  line-height: 1.7;
  max-width: 560px;
  margin: 0 auto 40px;
  opacity: 0.85;
}
.b2b-page .hero-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  font-size: 14px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}
.b2b-page .hero-cta a {
  color: #fff;
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.5);
  padding-bottom: 2px;
}
.b2b-page .hero-cta .divider { opacity: 0.4; }

/* WHO WE WORK WITH */
.b2b-page .who-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .who-tabs {
  display: flex;
  border: 1px solid var(--border);
  overflow: hidden;
}
.b2b-page .who-tab {
  flex: 1;
  padding: 28px 20px;
  text-align: center;
  font-size: 12px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border-right: 1px solid var(--border);
  font-weight: 500;
}
.b2b-page .who-tab:last-child { border-right: none; }
.b2b-page .who-tab-num {
  font-size: 24px;
  font-weight: 300;
  opacity: 0.15;
  display: block;
  margin-bottom: 10px;
}

/* CAPABILITIES */
.b2b-page .cap-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .cap-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
}
.b2b-page .cap-tile {
  position: relative;
  height: 360px;
  overflow: hidden;
  cursor: pointer;
}
.b2b-page .cap-tile-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  transition: transform 0.4s;
}
.b2b-page .cap-tile:hover .cap-tile-bg { transform: scale(1.04); }
.b2b-page .cap-tile-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.28);
}
.b2b-page .cap-tile-content {
  position: absolute;
  bottom: 28px;
  left: 28px;
  right: 28px;
}
.b2b-page .cap-tile-title {
  color: #fff;
  font-size: 14px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 12px;
  font-weight: 500;
}
.b2b-page .cap-expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28px;
  cursor: pointer;
  border: none;
  background: none;
  font-family: inherit;
  width: 100%;
}
.b2b-page .cap-expand-btn .circle-btn {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: 1px solid var(--dark);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.b2b-page .cap-expand-btn:hover .circle-btn { background: var(--dark); }
.b2b-page .cap-expand-btn:hover .circle-btn svg { stroke: #fff; }
.b2b-page .cap-expand-btn .circle-btn svg {
  width: 18px;
  height: 18px;
  stroke: var(--dark);
  fill: none;
  transition: transform 0.3s, stroke 0.2s;
}
.b2b-page .cap-expand-btn.open .circle-btn svg { transform: rotate(180deg); }
.b2b-page .cap-extra {
  display: none;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
  margin-top: 4px;
}
.b2b-page .cap-extra.open { display: grid; }

/* WHY PARTNER */
.b2b-page .why-section { border-bottom: 1px solid var(--border); }
.b2b-page .why-header {
  padding: 80px 80px 0;
  text-align: center;
}
.b2b-page .why-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 420px;
}
.b2b-page .why-row.reverse { direction: rtl; }
.b2b-page .why-row.reverse > * { direction: ltr; }
.b2b-page .why-img {
  background-size: cover;
  background-position: center;
  min-height: 420px;
}
.b2b-page .why-content {
  padding: 70px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--bg);
}
.b2b-page .why-label {
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  opacity: 0.4;
  margin-bottom: 16px;
}
.b2b-page .why-title {
  font-size: 20px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 24px;
  font-weight: 500;
  line-height: 1.4;
}
.b2b-page .why-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.b2b-page .why-list li {
  font-size: 15px;
  line-height: 1.6;
  opacity: 0.7;
  padding-left: 20px;
  position: relative;
  font-weight: 300;
}
.b2b-page .why-list li::before {
  content: '—';
  position: absolute;
  left: 0;
  opacity: 0.4;
}
.b2b-page .why-divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 0;
}

/* TESTIMONIALS */
.b2b-page .testi-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
  background: var(--dark);
}
.b2b-page .testi-section .section-label { color: rgba(255,255,255,0.4); }
.b2b-page .testi-section .section-title { color: #fff; }
.b2b-page .testi-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.b2b-page .testi-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 40px 36px;
}
.b2b-page .testi-quote {
  font-size: 16px;
  font-weight: 300;
  color: rgba(255,255,255,0.8);
  line-height: 1.75;
  margin-bottom: 28px;
  font-style: italic;
}
.b2b-page .testi-rule {
  width: 28px;
  height: 1px;
  background: rgba(255,255,255,0.25);
  margin-bottom: 18px;
}
.b2b-page .testi-name {
  font-size: 13px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  margin-bottom: 4px;
  font-weight: 500;
}
.b2b-page .testi-company {
  font-size: 13px;
  color: rgba(255,255,255,0.35);
  font-weight: 300;
}

/* PROCESS */
.b2b-page .process-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .process-timeline {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.b2b-page .process-item {
  display: flex;
  gap: 32px;
  padding: 40px 48px;
  border-bottom: 1px solid var(--border);
  border-right: 1px solid var(--border);
  align-items: flex-start;
}
.b2b-page .process-item:nth-child(even) { border-right: none; }
.b2b-page .process-item:nth-child(3),
.b2b-page .process-item:nth-child(4) { border-bottom: none; }
.b2b-page .process-num-big {
  font-size: 56px;
  font-weight: 300;
  line-height: 1;
  opacity: 0.1;
  flex-shrink: 0;
  width: 60px;
}
.b2b-page .process-step-title {
  font-size: 13px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 12px;
  font-weight: 500;
}
.b2b-page .process-step-text {
  font-size: 15px;
  line-height: 1.7;
  opacity: 0.6;
  font-weight: 300;
}

/* MID-PAGE CTA */
.b2b-page .midpage-cta {
  background: var(--dark);
  padding: 60px 80px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  border-bottom: 1px solid #333;
}
.b2b-page .midpage-cta-text {
  color: #fff;
  font-size: 24px;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.b2b-page .midpage-cta-sub {
  color: rgba(255,255,255,0.45);
  font-size: 15px;
  margin-top: 8px;
  font-weight: 300;
}
.b2b-page .btn-cta-white {
  display: inline-block;
  background: #fff;
  color: var(--dark);
  font-size: 13px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 16px 36px;
  text-decoration: none;
  white-space: nowrap;
  transition: opacity 0.2s;
  flex-shrink: 0;
}
.b2b-page .btn-cta-white:hover { opacity: 0.85; }

/* BENEFITS */
.b2b-page .benefits-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .benefits-v2 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid var(--border);
  border-left: 1px solid var(--border);
}
.b2b-page .benefit-v2 {
  padding: 40px 32px;
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.b2b-page svg.benefit-v2-icon {
  width: 44px;
  height: 44px;
  margin-bottom: 20px;
  stroke: #8b7355;
}
.b2b-page .benefit-v2-title {
  font-size: 13px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 10px;
  font-weight: 500;
}
.b2b-page .benefit-v2-text {
  font-size: 14px;
  line-height: 1.6;
  opacity: 0.55;
  font-weight: 300;
}

/* PORTFOLIO SLIDER */
.b2b-page .portfolio-section {
  padding: 80px;
  padding-bottom: 0;
  border-bottom: 1px solid var(--border);
}
.b2b-page .slider-wrap {
  position: relative;
  overflow: hidden;
}
.b2b-page .slider-track {
  display: flex;
  gap: 4px;
  transition: transform 0.5s ease;
}
.b2b-page .slide {
  min-width: calc(50% - 2px);
  aspect-ratio: 4/3;
  background-size: cover;
  background-position: center;
  flex-shrink: 0;
  position: relative;
}
.b2b-page .slide-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 55%);
}
.b2b-page .slide-info {
  position: absolute;
  bottom: 28px;
  left: 28px;
  right: 28px;
}
.b2b-page .slide-type {
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 6px;
}
.b2b-page .slide-name {
  font-size: 18px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #fff;
  font-weight: 500;
  margin-bottom: 6px;
}
.b2b-page .slide-services {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  font-weight: 300;
}
.b2b-page .slider-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.15);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
  z-index: 10;
  backdrop-filter: blur(4px);
}
.b2b-page .slider-arrow:hover { background: rgba(255,255,255,0.3); }
.b2b-page .slider-arrow svg { width: 16px; height: 16px; stroke: #fff; fill: none; }
.b2b-page .slider-arrow.left { left: 16px; }
.b2b-page .slider-arrow.right { right: 16px; }

/* WHY DESIGNERS */
.b2b-page .diff-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .diff-v2 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
}
.b2b-page .diff-card {
  position: relative;
  overflow: hidden;
  height: 380px;
}
.b2b-page .diff-card-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
}
.b2b-page .diff-card-blur {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
}
.b2b-page .diff-card-body {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24px 28px 28px;
}
.b2b-page .diff-card-title {
  font-size: 13px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 8px;
  color: #fff;
  font-weight: 500;
}
.b2b-page .diff-card-text {
  font-size: 14px;
  line-height: 1.6;
  color: rgba(255,255,255,0.75);
  font-weight: 300;
}

/* SHOWROOM */
.b2b-page .showroom-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 500px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .showroom-img {
  background-size: cover;
  background-position: center;
  min-height: 500px;
}
.b2b-page .showroom-content {
  padding: 80px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--bg);
}
.b2b-page .showroom-title {
  font-size: 15px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 24px;
  font-weight: 500;
}
.b2b-page .showroom-text {
  font-size: 17px;
  line-height: 1.8;
  opacity: 0.7;
  margin-bottom: 16px;
  font-weight: 300;
}
.b2b-page .showroom-address {
  font-size: 13px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.5;
  margin-bottom: 40px;
  line-height: 1.8;
}
.b2b-page .btn-outline {
  display: inline-block;
  border: 1px solid var(--dark);
  font-size: 13px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 14px 32px;
  text-decoration: none;
  color: var(--dark);
  transition: background 0.2s, color 0.2s;
}
.b2b-page .btn-outline:hover { background: var(--dark); color: #fff; }

/* FORM */
.b2b-page .form-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
  background: var(--white);
}
.b2b-page .form-wrap { max-width: 760px; margin: 0 auto; }
.b2b-page .form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 16px;
}
.b2b-page .form-field { display: flex; flex-direction: column; }
.b2b-page .form-field label {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  opacity: 0.5;
  margin-bottom: 8px;
}
.b2b-page .form-field input,
.b2b-page .form-field select {
  border: 1px solid var(--border);
  background: transparent;
  padding: 14px 16px;
  font-family: 'Instrument Sans', sans-serif;
  font-size: 15px;
  color: var(--dark);
  outline: none;
  -webkit-appearance: none;
  appearance: none;
  transition: border-color 0.2s;
  border-radius: 0;
}
.b2b-page .form-field input:focus,
.b2b-page .form-field select:focus { border-color: var(--dark); }
.b2b-page .form-field.full { grid-column: span 2; }
.b2b-page .form-submit {
  text-align: center;
  margin-top: 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.b2b-page .btn-dark {
  display: inline-block;
  background: var(--dark);
  color: #fff;
  font-size: 13px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 16px 48px;
  border: none;
  cursor: pointer;
  font-family: 'Instrument Sans', sans-serif;
  transition: opacity 0.2s;
}
.b2b-page .btn-dark:hover { opacity: 0.8; }
.b2b-page .form-note { font-size: 13px; opacity: 0.4; letter-spacing: 0.05em; }

/* CLOSING CTA */
.b2b-page .closing {
  position: relative;
  min-height: 460px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1510;
  overflow: hidden;
}
.b2b-page .closing-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #2d2820, #1a1510);
  opacity: 0.9;
}
.b2b-page .closing-inner {
  position: relative;
  text-align: center;
  padding: 80px 40px;
}
.b2b-page .closing-title {
  font-size: 36px;
  font-weight: 400;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 48px;
}
.b2b-page .closing-btns {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
}
.b2b-page .btn-white {
  display: inline-block;
  border: 1px solid rgba(255,255,255,0.6);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 14px 32px;
  text-decoration: none;
  color: #fff;
  transition: background 0.2s;
}
.b2b-page .btn-white:hover { background: rgba(255,255,255,0.1); }

/* MOBILE */
@media (max-width: 768px) {
  .b2b-page .section-title { margin-bottom: 30px; }
  .b2b-page .hero-content { padding: 0 24px; }
  .b2b-page .hero-title { font-size: 28px; }
  .b2b-page .hero-sub { font-size: 13px; }
  .b2b-page .hero-cta { flex-direction: column; gap: 10px; }
  .b2b-page .who-section { padding: 48px 24px; }
  .b2b-page .who-tabs { flex-wrap: wrap; }
  .b2b-page .who-tab { flex: 0 0 50%; border-bottom: 1px solid var(--border); }
  .b2b-page .who-tab:nth-child(even) { border-right: none; }
  .b2b-page .who-tab:nth-child(odd) { border-right: 1px solid var(--border); }
  .b2b-page .cap-section { padding: 48px 24px; }
  .b2b-page .cap-row { grid-template-columns: 1fr; }
  .b2b-page .cap-extra { grid-template-columns: 1fr; }
  .b2b-page .why-header { padding: 48px 24px 0; }
  .b2b-page .why-row { grid-template-columns: 1fr; }
  .b2b-page .why-row.reverse { direction: ltr; }
  .b2b-page .why-img { min-height: 260px; }
  .b2b-page .why-content { padding: 40px 24px; }
  .b2b-page .testi-section { padding: 48px 24px; }
  .b2b-page .testi-grid { grid-template-columns: 1fr; gap: 16px; }
  .b2b-page .process-section { padding: 48px 24px; }
  .b2b-page .process-timeline { grid-template-columns: 1fr; }
  .b2b-page .process-item { border-right: none !important; border-bottom: 1px solid var(--border) !important; padding: 32px 0; }
  .b2b-page .process-item:last-child { border-bottom: none !important; }
  .b2b-page .midpage-cta { flex-direction: column; align-items: flex-start; padding: 40px 24px; gap: 24px; }
  .b2b-page .benefits-section { padding: 48px 24px; }
  .b2b-page .benefits-v2 { grid-template-columns: repeat(2, 1fr); }
  .b2b-page .portfolio-section { padding: 48px 24px 0; }
