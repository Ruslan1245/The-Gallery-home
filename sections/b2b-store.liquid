    <div class="showroom-content">
      <p class="showroom-title">{{ section.settings.showroom_title }}</p>
      <p class="showroom-text">{{ section.settings.showroom_text1 }}</p>
      <p class="showroom-text">{{ section.settings.showroom_text2 }}</p>
      <p class="showroom-address">{{ section.settings.showroom_address | newline_to_br }}</p>
      <a href="{{ section.settings.showroom_btn_url }}" class="btn-outline">{{ section.settings.showroom_btn_text }}</a>
    </div>
  </div>

  <!-- FORM -->
  <div class="form-section" id="apply">
    <p class="section-label">{{ section.settings.form_label }}</p>
    <p class="section-title">{{ section.settings.form_title }}</p>
    <div class="form-wrap">
      {% form 'contact' %}
        {{ form.errors | default_errors }}
        <div class="form-grid">
          <div class="form-field">
            <label for="b2b-company">Company Name</label>
            <input type="text" id="b2b-company" name="contact[Company Name]" placeholder="Your company">
          </div>
          <div class="form-field">
            <label for="b2b-website">Website</label>
            <input type="text" id="b2b-website" name="contact[Website]" placeholder="yourwebsite.com">
          </div>
          <div class="form-field">
            <label for="b2b-contact">Contact Name</label>
            <input type="text" id="b2b-contact" name="contact[name]" placeholder="Full name" required>
          </div>
          <div class="form-field">
            <label for="b2b-email">Email</label>
            <input type="email" id="b2b-email" name="contact[email]" placeholder="email@company.com" required>
          </div>
          <div class="form-field">
            <label for="b2b-phone">Phone</label>
            <input type="tel" id="b2b-phone" name="contact[Phone]" placeholder="+971">
          </div>
          <div class="form-field">
            <label for="b2b-biz-type">Business Type</label>
            <select id="b2b-biz-type" name="contact[Business Type]">
              <option value="">Select...</option>
              <option>Interior Designer</option>
              <option>Architect</option>
              <option>Property Developer</option>
              <option>Hospitality</option>
              <option>Real Estate</option>
              <option>Holiday Home Operator</option>
              <option>Contractor</option>
            </select>
          </div>
          <div class="form-field">
            <label for="b2b-proj-type">Project Type</label>
            <select id="b2b-proj-type" name="contact[Project Type]">
              <option value="">Select...</option>
              <option>Residential</option>
              <option>Commercial</option>
              <option>Hospitality</option>
              <option>Mixed Use</option>
            </select>
          </div>
          <div class="form-field">
            <label for="b2b-spend">Estimated Annual Spend</label>
            <select id="b2b-spend" name="contact[Annual Spend]">
              <option value="">Select...</option>
              <option>Under AED 50,000</option>
              <option>AED 50,000 – 200,000</option>
              <option>AED 200,000 – 500,000</option>
              <option>AED 500,000+</option>
            </select>
          </div>
        </div>
        <div class="form-submit">
          <button type="submit" class="btn-dark">Apply For Trade Account</button>
          <p class="form-note">{{ section.settings.form_note }}</p>
        </div>
      {% endform %}
    </div>
  </div>

  <!-- CLOSING CTA -->
  <div class="closing">
    <div class="closing-bg"></div>
    <div class="closing-inner">
      <h2 class="closing-title">{{ section.settings.closing_title }}</h2>
      <div class="closing-btns">
        <a href="{{ section.settings.closing_btn1_url }}" class="btn-white">{{ section.settings.closing_btn1_text }}</a>
        <a href="{{ section.settings.closing_btn2_url }}" class="btn-white">{{ section.settings.closing_btn2_text }}</a>
      </div>
    </div>
  </div>

</div>

<script>
  function b2bToggleCap() {
    var extra = document.getElementById('b2bCapExtra');
    var btn = document.getElementById('b2bCapBtn');
    extra.classList.toggle('open');
    btn.classList.toggle('open');
    if (extra.classList.contains('open')) {
      btn.style.display = 'none';
    }
  }

  var b2bCurrent = 0;
  function b2bSlide(dir) {
    var track = document.getElementById('b2bSliderTrack');
    var slides = track.querySelectorAll('.slide');
    var visibleCount = window.innerWidth <= 768 ? 1 : 2;
    var maxPosition = slides.length - visibleCount;
    b2bCurrent = Math.max(0, Math.min(b2bCurrent + dir, maxPosition));
    var slideWidth = slides[0].offsetWidth + 4;
    track.style.transform = 'translateX(-' + (b2bCurrent * slideWidth) + 'px)';
  }
</script>

