        </div>
        <div class="form-submit">
          <button type="submit" class="btn-dark">Apply For Trade Account</button>
          <p class="form-note">Or call us directly: +971 4 431 0888</p>
        </div>
      {% endform %}
    </div>
  </div>

  <!-- CLOSING CTA -->
  <div class="closing">
    <div class="closing-bg"></div>
    <div class="closing-inner">
      <h2 class="closing-title">Let's Discuss Your Next Project</h2>
      <div class="closing-btns">
        <a href="#apply" class="btn-white">Book A Consultation</a>
        <a href="#apply" class="btn-white">Apply For Trade Account</a>
      </div>
    </div>
  </div>

</div>

<script>
  function b2bToggleCap() {
    var extra = document.getElementById('b2bCapExtra');
    var btn = document.getElementById('b2bCapBtn');
    extra.classList.toggle('open');
    btn.classList.toggle('open');
    if (extra.classList.contains('open')) {
      btn.style.display = 'none';
    }
  }

  var b2bCurrent = 0;
  function b2bSlide(dir) {
    var track = document.getElementById('b2bSliderTrack');
    var slides = track.querySelectorAll('.slide');
    var visibleCount = window.innerWidth <= 768 ? 1 : 2;
    var maxPosition = slides.length - visibleCount;
    b2bCurrent = Math.max(0, Math.min(b2bCurrent + dir, maxPosition));
    var slideWidth = slides[0].offsetWidth + 4;
    track.style.transform = 'translateX(-' + (b2bCurrent * slideWidth) + 'px)';
  }
</script>

