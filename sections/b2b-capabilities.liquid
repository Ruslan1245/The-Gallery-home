{% render 'b2b-styles' %}
<style>
.b2b-page .cap-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
}
.b2b-page .cap-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
}
.b2b-page .cap-tile {
  position: relative;
  height: 360px;
  overflow: hidden;
  cursor: pointer;
}
.b2b-page .cap-tile-bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  transition: transform 0.4s;
}
.b2b-page .cap-tile:hover .cap-tile-bg { transform: scale(1.04); }
.b2b-page .cap-tile-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.28);
}
.b2b-page .cap-tile-content {
  position: absolute;
  bottom: 28px;
  left: 28px;
  right: 28px;
}
.b2b-page .cap-tile-title {
  color: #fff;
  font-size: 14px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 12px;
  font-weight: 500;
}
.b2b-page .cap-expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28px;
  cursor: pointer;
  border: none;
  background: none;
  font-family: inherit;
  width: 100%;
}
.b2b-page .cap-expand-btn .circle-btn {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: 1px solid var(--dark);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.b2b-page .cap-expand-btn:hover .circle-btn { background: var(--dark); }
.b2b-page .cap-expand-btn:hover .circle-btn svg { stroke: #fff; }
.b2b-page .cap-expand-btn .circle-btn svg {
  width: 18px;
  height: 18px;
  stroke: var(--dark);
  fill: none;
  transition: transform 0.3s, stroke 0.2s;
}
.b2b-page .cap-expand-btn.open .circle-btn svg { transform: rotate(180deg); }
.b2b-page .cap-extra {
  display: none;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
  margin-top: 4px;
}
.b2b-page .cap-extra.open { display: grid; }
@media (max-width: 768px) {
  .b2b-page .cap-section { padding: 48px 24px; }
  .b2b-page .cap-row { grid-template-columns: 1fr; }
  .b2b-page .cap-extra { grid-template-columns: 1fr; }
}
</style>

<div class="cap-section">
  <p class="section-label">{{ section.settings.cap_label }}</p>
  <p class="section-title">{{ section.settings.cap_title }}</p>
  <div class="cap-row">
    <div class="cap-tile">
      <div class="cap-tile-bg" style="background-image:url('{% if section.settings.cap_tile_1_image != blank %}{{ section.settings.cap_tile_1_image | image_url: width: 800 }}{% else %}https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=800&q=80{% endif %}')"></div>
      <div class="cap-tile-overlay"></div>
      <div class="cap-tile-content">
        <p class="cap-tile-title">{{ section.settings.cap_tile_1_title }}</p>
      </div>
    </div>
    <div class="cap-tile">
      <div class="cap-tile-bg" style="background-image:url('{% if section.settings.cap_tile_2_image != blank %}{{ section.settings.cap_tile_2_image | image_url: width: 800 }}{% else %}https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?w=800&q=80{% endif %}')"></div>
      <div class="cap-tile-overlay"></div>
      <div class="cap-tile-content">
        <p class="cap-tile-title">{{ section.settings.cap_tile_2_title }}</p>
      </div>
    </div>
    <div class="cap-tile">
      <div class="cap-tile-bg" style="background-image:url('{% if section.settings.cap_tile_3_image != blank %}{{ section.settings.cap_tile_3_image | image_url: width: 800 }}{% else %}https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=800&q=80{% endif %}')"></div>
      <div class="cap-tile-overlay"></div>
      <div class="cap-tile-content">
        <p class="cap-tile-title">{{ section.settings.cap_tile_3_title }}</p>
      </div>
    </div>
  </div>

  <button class="cap-expand-btn" id="b2bCapBtn" onclick="b2bToggleCap()">
    <div class="circle-btn">
      <svg viewBox="0 0 18 16" stroke-width="1.5" fill="none" stroke="currentColor">
        <polyline points="2 5 9 11 16 5"/>
      </svg>
    </div>
  </button>

  <div class="cap-extra" id="b2bCapExtra">
    <div class="cap-tile">
      <div class="cap-tile-bg" style="background-image:url('{% if section.settings.cap_tile_4_image != blank %}{{ section.settings.cap_tile_4_image | image_url: width: 800 }}{% else %}https://images.unsplash.com/photo-1593696140826-c58b021acf8b?w=800&q=80{% endif %}')"></div>
      <div class="cap-tile-overlay"></div>
      <div class="cap-tile-content">
        <p class="cap-tile-title">{{ section.settings.cap_tile_4_title }}</p>
      </div>
    </div>
    <div class="cap-tile">
      <div class="cap-tile-bg" style="background-image:url('{% if section.settings.cap_tile_5_image != blank %}{{ section.settings.cap_tile_5_image | image_url: width: 800 }}{% else %}https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=80{% endif %}')"></div>
      <div class="cap-tile-overlay"></div>
      <div class="cap-tile-content">
        <p class="cap-tile-title">{{ section.settings.cap_tile_5_title }}</p>
      </div>
    </div>
    <div class="cap-tile">
      <div class="cap-tile-bg" style="background-image:url('{% if section.settings.cap_tile_6_image != blank %}{{ section.settings.cap_tile_6_image | image_url: width: 800 }}{% else %}https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?w=800&q=80{% endif %}')"></div>
      <div class="cap-tile-overlay"></div>
      <div class="cap-tile-content">
        <p class="cap-tile-title">{{ section.settings.cap_tile_6_title }}</p>
      </div>
    </div>
  </div>
</div>

<script>
  function b2bToggleCap() {
    var extra = document.getElementById('b2bCapExtra');
    var btn = document.getElementById('b2bCapBtn');
    extra.classList.toggle('open');
    btn.classList.toggle('open');
    if (extra.classList.contains('open')) {
      btn.style.display = 'none';
    }
  }
</script>

{% schema %}
{
  "name": "B2B — Our Capabilities",
  "tag": "div",
  "class": "b2b-page",
  "settings": [
    { "type": "text", "id": "cap_label", "label": "Section Label", "default": "What We Do" },
    { "type": "text", "id": "cap_title", "label": "Section Title", "default": "Our Capabilities" },
    { "type": "header", "content": "Tile 1" },
    { "type": "text", "id": "cap_tile_1_title", "label": "Title", "default": "Bespoke Furniture" },
    { "type": "image_picker", "id": "cap_tile_1_image", "label": "Image" },
    { "type": "header", "content": "Tile 2" },
    { "type": "text", "id": "cap_tile_2_title", "label": "Title", "default": "Bespoke Interiors" },
    { "type": "image_picker", "id": "cap_tile_2_image", "label": "Image" },
    { "type": "header", "content": "Tile 3" },
    { "type": "text", "id": "cap_tile_3_title", "label": "Title", "default": "Interior Design Service" },
    { "type": "image_picker", "id": "cap_tile_3_image", "label": "Image" },
    { "type": "header", "content": "Tile 4" },
    { "type": "text", "id": "cap_tile_4_title", "label": "Title", "default": "Media Walls & Joinery" },
    { "type": "image_picker", "id": "cap_tile_4_image", "label": "Image" },
    { "type": "header", "content": "Tile 5" },
    { "type": "text", "id": "cap_tile_5_title", "label": "Title", "default": "Marble & Travertine" },
    { "type": "image_picker", "id": "cap_tile_5_image", "label": "Image" },
    { "type": "header", "content": "Tile 6" },
    { "type": "text", "id": "cap_tile_6_title", "label": "Title", "default": "Full Home Furnishing" },
    { "type": "image_picker", "id": "cap_tile_6_image", "label": "Image" }
  ],
  "presets": [{ "name": "B2B — Our Capabilities" }]
}
{% endschema %}
