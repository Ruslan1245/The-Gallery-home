{% render 'b2b-styles' %}
<style>
.b2b-page .testi-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
  background: var(--dark);
}
.b2b-page .testi-section .section-label { color: rgba(255,255,255,0.4); }
.b2b-page .testi-section .section-title { color: #fff; }
.b2b-page .testi-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.b2b-page .testi-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 40px 36px;
}
.b2b-page .testi-quote {
  font-size: 16px;
  font-weight: 300;
  color: rgba(255,255,255,0.8);
  line-height: 1.75;
  margin-bottom: 28px;
  font-style: italic;
}
.b2b-page .testi-rule {
  width: 28px;
  height: 1px;
  background: rgba(255,255,255,0.25);
  margin-bottom: 18px;
}
.b2b-page .testi-name {
  font-size: 13px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  margin-bottom: 4px;
  font-weight: 500;
}
.b2b-page .testi-company {
  font-size: 13px;
  color: rgba(255,255,255,0.35);
  font-weight: 300;
}
@media (max-width: 768px) {
  .b2b-page .testi-section { padding: 48px 24px; }
  .b2b-page .testi-grid { grid-template-columns: 1fr; gap: 16px; }
}
</style>

<div class="testi-section">
  <p class="section-label">{{ section.settings.testi_label }}</p>
  <p class="section-title">{{ section.settings.testi_title }}</p>
  <div class="testi-grid">
    <div class="testi-card">
      <p class="testi-quote">"{{ section.settings.testi_1_quote }}"</p>
      <div class="testi-rule"></div>
      <p class="testi-name">{{ section.settings.testi_1_name }}</p>
      <p class="testi-company">{{ section.settings.testi_1_company }}</p>
    </div>
    <div class="testi-card">
      <p class="testi-quote">"{{ section.settings.testi_2_quote }}"</p>
      <div class="testi-rule"></div>
      <p class="testi-name">{{ section.settings.testi_2_name }}</p>
      <p class="testi-company">{{ section.settings.testi_2_company }}</p>
    </div>
    <div class="testi-card">
      <p class="testi-quote">"{{ section.settings.testi_3_quote }}"</p>
      <div class="testi-rule"></div>
      <p class="testi-name">{{ section.settings.testi_3_name }}</p>
      <p class="testi-company">{{ section.settings.testi_3_company }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "B2B — Testimonials",
  "tag": "div",
  "class": "b2b-page",
  "settings": [
    { "type": "text", "id": "testi_label", "label": "Section Label", "default": "Client Testimonials" },
    { "type": "text", "id": "testi_title", "label": "Section Title", "default": "What Our Trade Partners Say" },
    { "type": "header", "content": "Testimonial 1" },
    { "type": "textarea", "id": "testi_1_quote", "label": "Quote", "default": "The Gallery Home has become our go-to supplier for everything from bespoke joinery to full home furnishing packages. Their ability to deliver an entire villa project from one address saves us months of coordination." },
    { "type": "text", "id": "testi_1_name", "label": "Name", "default": "Sarah Al Mansoori" },
    { "type": "text", "id": "testi_1_company", "label": "Company", "default": "Principal Designer, SM Interiors — Dubai" },
    { "type": "header", "content": "Testimonial 2" },
    { "type": "textarea", "id": "testi_2_quote", "label": "Quote", "default": "Dubai-based manufacturing means we actually hit our install dates. We've used European suppliers before and the lead times were unworkable for our developer clients. The Gallery Home solves that completely." },
    { "type": "text", "id": "testi_2_name", "label": "Name", "default": "James Whitfield" },
    { "type": "text", "id": "testi_2_company", "label": "Company", "default": "Director, Whitfield Associates Architecture" },
    { "type": "header", "content": "Testimonial 3" },
    { "type": "textarea", "id": "testi_3_quote", "label": "Quote", "default": "From our first conversation to the final installation on a 24-apartment project, the level of communication was exceptional. Having a dedicated account manager who knows every detail of your project is invaluable." },
    { "type": "text", "id": "testi_3_name", "label": "Name", "default": "Lena Kowalski" },
    { "type": "text", "id": "testi_3_company", "label": "Company", "default": "Head of Interiors, Azizi Developments" }
  ],
  "presets": [{ "name": "B2B — Testimonials" }]
}
{% endschema %}
