{% render 'b2b-styles' %}
<style>
.b2b-page .form-section {
  padding: 80px;
  border-bottom: 1px solid var(--border);
  background: var(--white);
}
.b2b-page .form-wrap { max-width: 760px; margin: 0 auto; }
.b2b-page .form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 16px;
}
.b2b-page .form-field { display: flex; flex-direction: column; }
.b2b-page .form-field label {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  opacity: 0.5;
  margin-bottom: 8px;
}
.b2b-page .form-field input,
.b2b-page .form-field select {
  border: 1px solid var(--border);
  background: transparent;
  padding: 14px 16px;
  font-family: 'Instrument Sans', sans-serif;
  font-size: 15px;
  color: var(--dark);
  outline: none;
  -webkit-appearance: none;
  appearance: none;
  transition: border-color 0.2s;
  border-radius: 0;
}
.b2b-page .form-field input:focus,
.b2b-page .form-field select:focus { border-color: var(--dark); }
.b2b-page .form-field.full { grid-column: span 2; }
.b2b-page .form-submit {
  text-align: center;
  margin-top: 40px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.b2b-page .btn-dark {
  display: inline-block;
  background: var(--dark);
  color: #fff;
  font-size: 13px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 16px 48px;
  border: none;
  cursor: pointer;
  font-family: 'Instrument Sans', sans-serif;
  transition: opacity 0.2s;
}
.b2b-page .btn-dark:hover { opacity: 0.8; }
.b2b-page .form-note { font-size: 13px; opacity: 0.4; letter-spacing: 0.05em; }
@media (max-width: 768px) {
  .b2b-page .form-section { padding: 48px 24px; }
  .b2b-page .form-grid { grid-template-columns: 1fr; }
  .b2b-page .form-field.full { grid-column: span 1; }
}
</style>

<div class="form-section" id="apply">
  <p class="section-label">{{ section.settings.form_label }}</p>
  <p class="section-title">{{ section.settings.form_title }}</p>
  <div class="form-wrap">
    {% form 'contact' %}
      {{ form.errors | default_errors }}
      <div class="form-grid">
        <div class="form-field">
          <label for="b2b-company">Company Name</label>
          <input type="text" id="b2b-company" name="contact[Company Name]" placeholder="Your company">
        </div>
        <div class="form-field">
          <label for="b2b-website">Website</label>
          <input type="text" id="b2b-website" name="contact[Website]" placeholder="yourwebsite.com">
        </div>
        <div class="form-field">
          <label for="b2b-contact">Contact Name</label>
          <input type="text" id="b2b-contact" name="contact[name]" placeholder="Full name" required>
        </div>
        <div class="form-field">
          <label for="b2b-email">Email</label>
          <input type="email" id="b2b-email" name="contact[email]" placeholder="email@company.com" required>
        </div>
        <div class="form-field">
          <label for="b2b-phone">Phone</label>
          <input type="tel" id="b2b-phone" name="contact[Phone]" placeholder="+971">
        </div>
        <div class="form-field">
          <label for="b2b-biz-type">Business Type</label>
          <select id="b2b-biz-type" name="contact[Business Type]">
            <option value="">Select...</option>
            <option>Interior Designer</option>
            <option>Architect</option>
            <option>Property Developer</option>
            <option>Hospitality</option>
            <option>Real Estate</option>
            <option>Holiday Home Operator</option>
            <option>Contractor</option>
          </select>
        </div>
        <div class="form-field">
          <label for="b2b-proj-type">Project Type</label>
          <select id="b2b-proj-type" name="contact[Project Type]">
            <option value="">Select...</option>
            <option>Residential</option>
            <option>Commercial</option>
            <option>Hospitality</option>
            <option>Mixed Use</option>
          </select>
        </div>
        <div class="form-field">
          <label for="b2b-spend">Estimated Annual Spend</label>
          <select id="b2b-spend" name="contact[Annual Spend]">
            <option value="">Select...</option>
            <option>Under AED 50,000</option>
            <option>AED 50,000 – 200,000</option>
            <option>AED 200,000 – 500,000</option>
            <option>AED 500,000+</option>
          </select>
        </div>
      </div>
      <div class="form-submit">
        <button type="submit" class="btn-dark">{{ section.settings.form_btn_text }}</button>
        <p class="form-note">{{ section.settings.form_note }}</p>
      </div>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "B2B — Application Form",
  "tag": "div",
  "class": "b2b-page",
  "settings": [
    { "type": "text", "id": "form_label", "label": "Section Label", "default": "Get Started" },
    { "type": "text", "id": "form_title", "label": "Section Title", "default": "Apply For A Trade Account" },
    { "type": "text", "id": "form_btn_text", "label": "Submit Button Text", "default": "Apply For Trade Account" },
    { "type": "text", "id": "form_note", "label": "Note Below Button", "default": "Or call us directly: +971 4 431 0888" }
  ],
  "presets": [{ "name": "B2B — Application Form" }]
}
{% endschema %}
