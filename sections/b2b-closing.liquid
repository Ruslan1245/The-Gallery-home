{% render 'b2b-styles' %}
<style>
.b2b-page .closing {
  position: relative;
  min-height: 460px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1510;
  overflow: hidden;
}
.b2b-page .closing-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #2d2820, #1a1510);
  opacity: 0.9;
}
.b2b-page .closing-inner {
  position: relative;
  text-align: center;
  padding: 80px 40px;
}
.b2b-page .closing-title {
  font-size: 36px;
  font-weight: 400;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 48px;
}
.b2b-page .closing-btns {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
}
.b2b-page .btn-white {
  display: inline-block;
  border: 1px solid rgba(255,255,255,0.6);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 14px 32px;
  text-decoration: none;
  color: #fff;
  transition: background 0.2s;
}
.b2b-page .btn-white:hover { background: rgba(255,255,255,0.1); }
@media (max-width: 768px) {
  .b2b-page .closing-inner { padding: 60px 24px; }
  .b2b-page .closing-title { font-size: 24px; }
  .b2b-page .closing-btns { flex-direction: column; align-items: center; }
}
</style>

<div class="closing">
  <div class="closing-bg"></div>
  <div class="closing-inner">
    <h2 class="closing-title">{{ section.settings.closing_title }}</h2>
    <div class="closing-btns">
      <a href="{{ section.settings.closing_btn1_url }}" class="btn-white">{{ section.settings.closing_btn1_text }}</a>
      <a href="{{ section.settings.closing_btn2_url }}" class="btn-white">{{ section.settings.closing_btn2_text }}</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "B2B — Closing CTA",
  "tag": "div",
  "class": "b2b-page",
  "settings": [
    { "type": "text", "id": "closing_title", "label": "Title", "default": "Let's Discuss Your Next Project" },
    { "type": "text", "id": "closing_btn1_text", "label": "Button 1 Text", "default": "Book A Consultation" },
    { "type": "text", "id": "closing_btn1_url", "label": "Button 1 URL", "default": "#apply" },
    { "type": "text", "id": "closing_btn2_text", "label": "Button 2 Text", "default": "Apply For Trade Account" },
    { "type": "text", "id": "closing_btn2_url", "label": "Button 2 URL", "default": "#apply" }
  ],
  "presets": [{ "name": "B2B — Closing CTA" }]
}
{% endschema %}
