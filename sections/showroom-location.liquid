{%- assign color_scheme_hash = section.settings.color_scheme.settings.background_gradient | default: section.settings.color_scheme.settings.background | md5 -%}

<div class="color-scheme color-scheme--{{ section.settings.color_scheme.id }} color-scheme--bg-{{ color_scheme_hash }} {% unless section.settings.remove_vertical_spacing %}section-spacing{% endunless %} {% if section.settings.separate_section_with_border %}bordered-section{% endif %}">
  <div class="container">

    {%- if section.settings.intro_text != blank -%}
      <div class="showroom-location__intro">
        <p>{{ section.settings.intro_text }}</p>
      </div>
    {%- endif -%}

    <div class="showroom-location__card">
      <div class="showroom-location__info">

        {%- if section.settings.label != blank -%}
          <p class="showroom-location__label">{{ section.settings.label }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="showroom-location__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.address != blank -%}
          <div class="showroom-location__detail">
            <p class="showroom-location__detail-label">{{ section.settings.address_label | default: 'Address' }}</p>
            <div class="showroom-location__detail-content">{{ section.settings.address | newline_to_br }}</div>
          </div>
        {%- endif -%}

        {%- if section.settings.hours != blank -%}
          <div class="showroom-location__detail">
            <p class="showroom-location__detail-label">{{ section.settings.hours_label | default: 'Opening Hours' }}</p>
            <div class="showroom-location__detail-content">{{ section.settings.hours | newline_to_br }}</div>
          </div>
        {%- endif -%}

        {%- if section.settings.phone != blank or section.settings.email != blank -%}
          <div class="showroom-location__detail">
            <p class="showroom-location__detail-label">{{ section.settings.contact_label | default: 'Contact' }}</p>
            <div class="showroom-location__detail-content">
              {%- if section.settings.phone != blank -%}
                <p><a href="tel:{{ section.settings.phone | replace: ' ', '' }}">{{ section.settings.phone }}</a></p>
              {%- endif -%}
              {%- if section.settings.email != blank -%}
                <p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>

      <div class="showroom-location__map">
        {%- if section.settings.embed_url != blank -%}
          {%- assign map_src = section.settings.embed_url -%}
        {%- else -%}
          {%- assign map_query = section.settings.map_query | url_encode -%}
          {%- assign map_src = 'https://maps.google.com/maps?q=' | append: map_query | append: '&t=&z=' | append: section.settings.map_zoom | append: '&ie=UTF8&iwloc=&output=embed' -%}
        {%- endif -%}
        <iframe
          src="{{ map_src }}"
          width="100%"
          height="100%"
          style="border:0; min-height: {{ section.settings.map_height }}px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="{{ section.settings.heading | escape }} map"
        ></iframe>
      </div>
    </div>

  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .showroom-location__intro {
    max-width: 700px;
    margin-inline: auto;
    text-align: center;
    margin-bottom: 3rem;
    font-size: 1.05em;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .showroom-location__card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: #fff;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 24px 0 rgba(0,0,0,0.06);
  }

  #shopify-section-{{ section.id }} .showroom-location__info {
    padding: 3rem 2.5rem;
  }

  #shopify-section-{{ section.id }} .showroom-location__label {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 1rem;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .showroom-location__heading {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.15;
    margin-bottom: 2rem;
    font-weight: 400;
  }

  #shopify-section-{{ section.id }} .showroom-location__detail {
    border-left: 2px solid {{ section.settings.accent_color }};
    padding-left: 1rem;
    margin-bottom: 1.5rem;
  }

  #shopify-section-{{ section.id }} .showroom-location__detail-label {
    font-size: 0.65rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: currentColor;
    opacity: 0.55;
    margin-bottom: 0.4rem;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .showroom-location__detail-content {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .showroom-location__detail-content a {
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .showroom-location__detail-content a:hover {
    text-decoration: underline;
  }

  #shopify-section-{{ section.id }} .showroom-location__map {
    min-height: {{ section.settings.map_height }}px;
    position: relative;
  }

  #shopify-section-{{ section.id }} .showroom-location__map iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .showroom-location__card {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .showroom-location__map {
      min-height: 300px;
    }

    #shopify-section-{{ section.id }} .showroom-location__map iframe {
      position: static;
      height: 300px;
    }

    #shopify-section-{{ section.id }} .showroom-location__info {
      padding: 2rem 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Showroom Location",
  "class": "shopify-section--showroom-location",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "t:global.section.separate_section_with_border",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "remove_vertical_spacing",
      "label": "t:global.spacing.remove_vertical_spacing",
      "default": false
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent colour",
      "default": "#B8963E"
    },
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro paragraph",
      "default": "Step into our Dubai Hills showroom to connect with our in-house design team, explore a carefully curated selection of materials and finishes, and experience the exceptional craftsmanship behind every bespoke piece we create."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Our Location"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dubai Hills Estate Showroom"
    },
    {
      "type": "header",
      "content": "Address"
    },
    {
      "type": "text",
      "id": "address_label",
      "label": "Address label",
      "default": "Address"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "Dubai Hills Estate\nDubai, United Arab Emirates"
    },
    {
      "type": "header",
      "content": "Opening Hours"
    },
    {
      "type": "text",
      "id": "hours_label",
      "label": "Opening hours label",
      "default": "Opening Hours"
    },
    {
      "type": "textarea",
      "id": "hours",
      "label": "Opening hours",
      "default": "Sunday - Thursday: 9:00 AM - 6:00 PM\nSaturday: 10:00 AM - 4:00 PM\nFriday: Closed"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact label",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+971 4 XXX XXXX"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "showroom@thegalleryhome.ae"
    },
    {
      "type": "header",
      "content": "Map"
    },
    {
      "type": "text",
      "id": "embed_url",
      "label": "Google Maps embed URL (recommended)",
      "info": "Paste the src URL from Google Maps → Share → Embed a map. This centers the map on your exact pin. If set, overrides the search query below.",
      "default": "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3612.7030879601307!2d55.24800617604148!3d25.11191017776604!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xe99bf723dc93275%3A0x5c11560adf219c53!2sThe%20Gallery%20Home!5e0!3m2!1sen!2spl!4v1777932811803!5m2!1sen!2spl"
    },
    {
      "type": "text",
      "id": "map_query",
      "label": "Map search query (fallback)",
      "info": "Used only if no embed URL is set above. Enter an address or place name.",
      "default": "Dubai Hills Estate, Dubai, UAE"
    },
    {
      "type": "range",
      "id": "map_zoom",
      "min": 10,
      "max": 20,
      "step": 1,
      "label": "Map zoom level",
      "default": 15
    },
    {
      "type": "range",
      "id": "map_height",
      "min": 300,
      "max": 700,
      "step": 20,
      "unit": "px",
      "label": "Map height",
      "default": 480
    }
  ],
  "presets": [
    {
      "name": "Showroom Location"
    }
  ]
}
{% endschema %}
