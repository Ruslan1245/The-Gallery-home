    { "type": "header", "content": "Slide 6" },
    { "type": "image_picker", "id": "slide_6_image", "label": "Image" },
    { "type": "text", "id": "slide_6_type", "label": "Category", "default": "Developer — Downtown Dubai" },
    { "type": "text", "id": "slide_6_name", "label": "Project Name", "default": "24-Unit Apartment Package" },
    { "type": "text", "id": "slide_6_services", "label": "Services", "default": "Furniture · Wardrobes · Marble Feature Walls" }
  ],
  "presets": [{ "name": "B2B — Portfolio" }]
}
