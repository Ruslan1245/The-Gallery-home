    { "type": "text", "id": "portfolio_label", "label": "Section Label", "default": "Portfolio" },
    { "type": "text", "id": "portfolio_title", "label": "Section Title", "default": "Recent Projects" },
    { "type": "header", "content": "Slide 1" },
